{
  "name": "localvtt",
  "version": "0.1.11",
  "private": true,
  "description": "Local-first tabletop battle map display tool for in-person RPG sessions.",
  "author": "Local VTT contributors",
  "main": "dist-electron/electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "npm run build:electron && concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "build": "npm run typecheck && npm run build:electron && vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "check": "npm run typecheck && npm run lint && npm test",
    "postinstall": "node scripts/ensure-electron.mjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "electron:install": "node scripts/ensure-electron.mjs",
    "smoke:electron": "npm run build && npm run electron:install && node tests/electron/smoke.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "generate:icon": "node scripts/generate-icon.mjs",
    "package:mac": "npm run build && electron-builder --mac",
    "package:win": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "@dimforge/rapier3d-compat": "^0.12.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.13.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "lucide-react": "^1.17.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.184.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.1.0",
    "vitest": "^4.1.8",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "app.localvtt.desktop",
    "productName": "Local VTT",
    "files": [
      "dist/**",
      "dist-electron/**",
      "build/icon.ico",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.games",
      "icon": "build/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "Local VTT"
    }
  }
}
